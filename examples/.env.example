# Copy to examples/.env and fill in your key:  cp examples/.env.example examples/.env
# examples/.env is gitignored — never commit your real license key.

AIC_SDK_LICENSE=your-license-key-here

# Optional overrides:
# AIC_SDK_MODEL=/absolute/path/to/model.aicmodel   # defaults to spec/fixtures/model.aicmodel
# ENHANCEMENT_LEVEL=1.0                             # 0.0 (off) .. 1.0 (max)
